# oil-inventory-dashboard configuration.
# Copy to .env and fill in. Leave any block blank to disable that pipeline —
# the dashboard will hide its setup row and skip its scheduler job.

# ── Required for EIA ingestion ────────────────────────────────────────────
# Optional. If set, the dashboard uses the EIA v2 API (faster, more reliable).
# If unset, it falls back to public XLS downloads — no key required, but a few
# series are slower to refresh.
# Get one free: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# ── Required for AIS tanker positions ─────────────────────────────────────
# aisstream.io WebSocket key — drives the global tanker map.
# Get one free: https://aisstream.io
AISSTREAM_API_KEY=

# ── Required for Sentinel-1 SAR detections ────────────────────────────────
# Copernicus Data Space Ecosystem (CDSE) OAuth client credentials.
# IMPORTANT: SAR ingest costs Sentinel Hub Processing Units (PUs). The free
# tier is ~30k PU/month — you can blow through that in a few days if you add
# AOIs aggressively. See README "Costs & quotas" before enabling.
# Get credentials free: https://dataspace.copernicus.eu  (Settings → OAuth clients)
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=

# Set to "false" to disable SAR ingest even when CDSE creds are present.
# Default: enabled when CDSE creds are present, disabled otherwise.
# SAR_ENABLED=false

# ── Storage ───────────────────────────────────────────────────────────────
# Where the dashboard reads/writes data. Default: <repo>/data/
# In Docker: /data (set by Dockerfile, override with a bind mount).
# DATA_DIR=/path/to/data

# Override the sqlite path explicitly (default: $DATA_DIR/eia-dashboard/eia_data.db)
# EIA_DB_PATH=/path/to/eia_data.db

# ── Optional ──────────────────────────────────────────────────────────────
# Override which .env file is loaded (default: <repo>/.env).
# Useful for docker secrets or shared workspace .env in a parent repo.
# ENV_FILE=/run/secrets/oil-dashboard.env

# Timezone for scheduled jobs (UTC is the default; cron expressions are UTC).
# TZ=UTC
